{
  "expo": {
    "name": "Vox",
    "slug": "vox",
    "version": "0.1.0",
    "scheme": "vox",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "qa.uts.vox",
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Vox uses the camera for video calls.",
        "NSMicrophoneUsageDescription": "Vox uses the microphone for voice and video calls."
      }
    },
    "android": {
      "package": "qa.uts.vox",
      "permissions": ["CAMERA", "RECORD_AUDIO", "INTERNET"]
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": false
    }
  }
}
